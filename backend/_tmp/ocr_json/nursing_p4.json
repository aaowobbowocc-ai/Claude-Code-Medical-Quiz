[{"text": "代號：5106", "conf": 0.9993175864219666, "xmin": 59.0, "xmax": 368.0, "ymin": 86.0, "ymax": 159.0, "cx": 213.5, "cy": 122.5}, {"text": "頁次：8-4", "conf": 0.9919114112854004, "xmin": 61.0, "xmax": 341.0, "ymin": 148.0, "ymax": 224.0, "cx": 201.0, "cy": 186.0}, {"text": "26", "conf": 0.9999185800552368, "xmin": 66.0, "xmax": 143.0, "ymin": 267.0, "ymax": 332.0, "cx": 104.25, "cy": 299.5}, {"text": "人格障礙症病人無法感受症狀所帶來的痛苦，所以病人極少認為有治療的必要，一般都是性格問題", "conf": 0.9996036887168884, "xmin": 196.0, "xmax": 2327.0, "ymin": 277.0, "ymax": 386.0, "cx": 1261.75, "cy": 331.25}, {"text": "導致生活適應上產生障礙，才會到精神科求診，因此治療重點包括下列何者？①改變病人個性本質", "conf": 0.9993135333061218, "xmin": 196.0, "xmax": 2325.0, "ymin": 361.0, "ymax": 464.0, "cx": 1260.5, "cy": 412.5}, {"text": "②改善導致其困擾之症狀", "conf": 0.9979749321937561, "xmin": 201.0, "xmax": 753.0, "ymin": 450.0, "ymax": 521.0, "cx": 477.0, "cy": 485.5}, {"text": "③給予情緒支持", "conf": 0.9890931248664856, "xmin": 793.0, "xmax": 1131.0, "ymin": 470.0, "ymax": 518.0, "cx": 962.0, "cy": 494.0}, {"text": "④增進病人適應生活及適應環境的能力", "conf": 0.9970744848251343, "xmin": 1182.0, "xmax": 2007.0, "ymin": 471.0, "ymax": 527.0, "cx": 1594.75, "cy": 499.0}, {"text": "(A)①②③", "conf": 0.9792757034301758, "xmin": 198.0, "xmax": 415.0, "ymin": 527.0, "ymax": 600.0, "cx": 306.5, "cy": 563.5}, {"text": "(B)①②④", "conf": 0.976040780544281, "xmin": 720.0, "xmax": 912.0, "ymin": 546.0, "ymax": 602.0, "cx": 816.25, "cy": 574.0}, {"text": "(C)①③④", "conf": 0.956920862197876, "xmin": 1249.0, "xmax": 1445.0, "ymin": 546.0, "ymax": 601.0, "cx": 1346.75, "cy": 573.5}, {"text": "(D)②③④", "conf": 0.9027758240699768, "xmin": 1777.0, "xmax": 1978.0, "ymin": 555.0, "ymax": 608.0, "cx": 1877.5, "cy": 581.5}, {"text": "27", "conf": 0.9998931884765625, "xmin": 70.0, "xmax": 145.0, "ymin": 598.0, "ymax": 659.0, "cx": 107.25, "cy": 628.5}, {"text": "照護妄想型人格障礙症病人，為使病人至少可以信任一些人的態度，其治療首重下列何者？", "conf": 0.9974104762077332, "xmin": 196.0, "xmax": 2150.0, "ymin": 603.0, "ymax": 703.0, "cx": 1173.0, "cy": 653.0}, {"text": "(A)評估病人自殺意念", "conf": 0.9923729300498962, "xmin": 202.0, "xmax": 652.0, "ymin": 691.0, "ymax": 757.0, "cx": 427.25, "cy": 724.0}, {"text": "(B)引導病人注意自己的行為", "conf": 0.9408945441246033, "xmin": 1252.0, "xmax": 1830.0, "ymin": 705.0, "ymax": 758.0, "cx": 1541.0, "cy": 731.75}, {"text": "(C)建立治療性人際關係", "conf": 0.9847514033317566, "xmin": 201.0, "xmax": 699.0, "ymin": 770.0, "ymax": 833.0, "cx": 450.0, "cy": 801.5}, {"text": "(D)協助病人認知合作及妥協的重要性", "conf": 0.993352472782135, "xmin": 1249.0, "xmax": 2033.0, "ymin": 780.0, "ymax": 841.0, "cx": 1640.75, "cy": 810.5}, {"text": "28", "conf": 0.9999186992645264, "xmin": 68.0, "xmax": 145.0, "ymin": 835.0, "ymax": 899.0, "cx": 106.25, "cy": 867.0}, {"text": "邊緣型人格障礙症病人有挑撥與討好的人際互動、情緒及明顯的衝動，最適宜的護理措施為下列何", "conf": 0.9827381372451782, "xmin": 199.0, "xmax": 2325.0, "ymin": 846.0, "ymax": 929.0, "cx": 1262.0, "cy": 887.25}, {"text": "者？", "conf": 0.9084916114807129, "xmin": 194.0, "xmax": 306.0, "ymin": 920.0, "ymax": 990.0, "cx": 250.0, "cy": 955.0}, {"text": "(A)建立良好的治療性人際關係", "conf": 0.9982134103775024, "xmin": 201.0, "xmax": 841.0, "ymin": 1006.0, "ymax": 1067.0, "cx": 520.75, "cy": 1036.5}, {"text": "(B)避免被病人操縱", "conf": 0.9825726747512817, "xmin": 1249.0, "xmax": 1639.0, "ymin": 1019.0, "ymax": 1077.0, "cx": 1443.75, "cy": 1048.0}, {"text": "(C)與病人訂契約保證不自殺", "conf": 0.9885077476501465, "xmin": 200.0, "xmax": 794.0, "ymin": 1086.0, "ymax": 1147.0, "cx": 497.0, "cy": 1116.5}, {"text": "(D)教導認識社會心理壓力", "conf": 0.982212483882904, "xmin": 1249.0, "xmax": 1784.0, "ymin": 1097.0, "ymax": 1162.0, "cx": 1516.5, "cy": 1129.25}, {"text": "29", "conf": 0.9999616146087646, "xmin": 71.0, "xmax": 142.0, "ymin": 1161.0, "ymax": 1219.0, "cx": 106.5, "cy": 1190.0}, {"text": "有關Methylphenidate（Ritalin）的敘述，下列何者錯誤？", "conf": 0.9787624478340149, "xmin": 196.0, "xmax": 1399.0, "ymin": 1162.0, "ymax": 1237.0, "cx": 797.5, "cy": 1199.25}, {"text": "(A)改善病童的過動與衝動", "conf": 0.9947242140769958, "xmin": 201.0, "xmax": 748.0, "ymin": 1243.0, "ymax": 1306.0, "cx": 474.5, "cy": 1274.5}, {"text": "(B)容易有食慾不振的問題", "conf": 0.9890660643577576, "xmin": 1248.0, "xmax": 1788.0, "ymin": 1256.0, "ymax": 1324.0, "cx": 1518.0, "cy": 1290.25}, {"text": "(C)最適合的服藥時間是傍晚至夜間", "conf": 0.990628182888031, "xmin": 202.0, "xmax": 935.0, "ymin": 1325.0, "ymax": 1387.0, "cx": 568.5, "cy": 1356.0}, {"text": "(D)可以在寒暑假或放假時暫停服藥", "conf": 0.9914880394935608, "xmin": 1246.0, "xmax": 1991.0, "ymin": 1338.0, "ymax": 1405.0, "cx": 1618.75, "cy": 1371.5}, {"text": "30", "conf": 0.9998700022697449, "xmin": 69.0, "xmax": 144.0, "ymin": 1397.0, "ymax": 1458.0, "cx": 106.25, "cy": 1427.5}, {"text": "對於失智症病人的護理措施，下列何者正確？", "conf": 0.9900981783866882, "xmin": 200.0, "xmax": 1166.0, "ymin": 1404.0, "ymax": 1468.0, "cx": 682.75, "cy": 1435.75}, {"text": "(A)環境儘量多樣化，以增加刺激", "conf": 0.9973921775817871, "xmin": 202.0, "xmax": 888.0, "ymin": 1484.0, "ymax": 1544.0, "cx": 545.0, "cy": 1514.25}, {"text": "(B)若病人夜裡睡眠紊亂，白天時調暗燈光，讓病人補充睡眠", "conf": 0.9983466863632202, "xmin": 202.0, "xmax": 1471.0, "ymin": 1564.0, "ymax": 1629.0, "cx": 836.25, "cy": 1596.5}, {"text": "(C)儘量安排不同護理人員照顧，以增加病人對護理人員的熟悉", "conf": 0.9965478777885437, "xmin": 204.0, "xmax": 1517.0, "ymin": 1645.0, "ymax": 1707.0, "cx": 860.5, "cy": 1676.0}, {"text": "(D)鼓勵家屬自家中帶病人熟悉的物品置於病人的房間，並儘量不更動擺設", "conf": 0.9975994229316711, "xmin": 205.0, "xmax": 1766.0, "ymin": 1723.0, "ymax": 1791.0, "cx": 985.25, "cy": 1757.0}, {"text": "31", "conf": 0.9999353289604187, "xmin": 73.0, "xmax": 140.0, "ymin": 1794.0, "ymax": 1851.0, "cx": 106.5, "cy": 1822.5}, {"text": "有關老年精神病人的護理評估原則，下列何者正確？", "conf": 0.996414840221405, "xmin": 205.0, "xmax": 1305.0, "ymin": 1803.0, "ymax": 1863.0, "cx": 754.75, "cy": 1833.0}, {"text": "(A)老年病人記性差，不論時間長短，收集資料宜一次完成", "conf": 0.9977924227714539, "xmin": 207.0, "xmax": 1417.0, "ymin": 1882.0, "ymax": 1945.0, "cx": 812.0, "cy": 1913.5}, {"text": "(B)老年病人愛回顧過去生命經驗，基於此時此刻原則，此部分資料不須收集", "conf": 0.9980900287628174, "xmin": 207.0, "xmax": 1816.0, "ymin": 1959.0, "ymax": 2030.0, "cx": 1011.75, "cy": 1994.25}, {"text": "(C)老年病人對問題反應很慢或無法適當回答，可以改變問法試試看", "conf": 0.9974898099899292, "xmin": 208.0, "xmax": 1614.0, "ymin": 2036.0, "ymax": 2105.0, "cx": 910.75, "cy": 2070.75}, {"text": "(D)老年病人因為記憶力和判斷力都不好，因此僅以家屬所敘述為主", "conf": 0.9979548454284668, "xmin": 206.0, "xmax": 1612.0, "ymin": 2113.0, "ymax": 2186.0, "cx": 909.0, "cy": 2149.5}, {"text": "32", "conf": 0.9999182820320129, "xmin": 75.0, "xmax": 147.0, "ymin": 2190.0, "ymax": 2250.0, "cx": 111.0, "cy": 2220.0}, {"text": "李小姐參加複健商店的工作訓練，此為第幾級的預防概念？", "conf": 0.977961540222168, "xmin": 205.0, "xmax": 1450.0, "ymin": 2194.0, "ymax": 2266.0, "cx": 827.5, "cy": 2229.75}, {"text": "(A)第一級預防", "conf": 0.9394758939743042, "xmin": 211.0, "xmax": 500.0, "ymin": 2279.0, "ymax": 2329.0, "cx": 355.5, "cy": 2304.0}, {"text": "(B)第二級預防", "conf": 0.966204047203064, "xmin": 714.0, "xmax": 998.0, "ymin": 2278.0, "ymax": 2338.0, "cx": 856.0, "cy": 2308.0}, {"text": "(C)第三級預防", "conf": 0.9136732816696167, "xmin": 1240.0, "xmax": 1529.0, "ymin": 2291.0, "ymax": 2345.0, "cx": 1384.5, "cy": 2318.25}, {"text": "(D)第四級預防", "conf": 0.9740722179412842, "xmin": 1771.0, "xmax": 2081.0, "ymin": 2292.0, "ymax": 2355.0, "cx": 1926.0, "cy": 2323.5}, {"text": "33", "conf": 0.9998782277107239, "xmin": 77.0, "xmax": 144.0, "ymin": 2355.0, "ymax": 2410.0, "cx": 110.5, "cy": 2382.5}, {"text": "慢性精神病人參與庇護性工場活動之訓練目的，下列何者正確？", "conf": 0.9907416701316833, "xmin": 206.0, "xmax": 1546.0, "ymin": 2354.0, "ymax": 2425.0, "cx": 876.25, "cy": 2389.5}, {"text": "(A)增強面對高壓力情境的工作技能", "conf": 0.9907408356666565, "xmin": 208.0, "xmax": 922.0, "ymin": 2438.0, "ymax": 2491.0, "cx": 565.0, "cy": 2464.5}, {"text": "(B)提供工作態度和工作能力的訓練", "conf": 0.9952883124351501, "xmin": 1237.0, "xmax": 1983.0, "ymin": 2446.0, "ymax": 2511.0, "cx": 1610.0, "cy": 2478.25}, {"text": "(C)做為競爭性工作的基礎", "conf": 0.8950662612915039, "xmin": 209.0, "xmax": 732.0, "ymin": 2518.0, "ymax": 2565.0, "cx": 470.5, "cy": 2541.25}, {"text": "(D)達到自給自足的收入", "conf": 0.9406567215919495, "xmin": 1236.0, "xmax": 1724.0, "ymin": 2525.0, "ymax": 2582.0, "cx": 1480.0, "cy": 2553.5}, {"text": "34", "conf": 0.999808669090271, "xmin": 74.0, "xmax": 145.0, "ymin": 2589.0, "ymax": 2643.0, "cx": 109.5, "cy": 2616.0}, {"text": "社區精神衛生護理師的主要角色功能，下列何者正確？", "conf": 0.9903908371925354, "xmin": 202.0, "xmax": 1346.0, "ymin": 2590.0, "ymax": 2654.0, "cx": 774.0, "cy": 2622.25}, {"text": "(A)不可單獨在社區進行團體諮詢活動", "conf": 0.9918631315231323, "xmin": 206.0, "xmax": 967.0, "ymin": 2673.0, "ymax": 2723.0, "cx": 586.5, "cy": 2698.0}, {"text": "(B)宜促進病人與醫療人員之間的訊息溝通與聯繫", "conf": 0.9966575503349304, "xmin": 1230.0, "xmax": 2277.0, "ymin": 2675.0, "ymax": 2755.0, "cx": 1753.5, "cy": 2715.0}, {"text": "(C)擬定護理計畫需以功利成效為導向", "conf": 0.9689764380455017, "xmin": 204.0, "xmax": 963.0, "ymin": 2750.0, "ymax": 2802.0, "cx": 583.5, "cy": 2776.0}, {"text": "(D)發現心理困擾者須宣導藥物治療的優先性", "conf": 0.9920884370803833, "xmin": 1230.0, "xmax": 2170.0, "ymin": 2758.0, "ymax": 2831.0, "cx": 1700.0, "cy": 2794.5}, {"text": "有關以社區為基礎的精神醫學治療模式，下列何者正確？", "conf": 0.9979580044746399, "xmin": 196.0, "xmax": 1396.0, "ymin": 2819.0, "ymax": 2896.0, "cx": 796.0, "cy": 2857.75}, {"text": "35", "conf": 0.9998703598976135, "xmin": 70.0, "xmax": 139.0, "ymin": 2829.0, "ymax": 2883.0, "cx": 104.5, "cy": 2856.0}, {"text": "(A)強調在醫院中持續複健治療", "conf": 0.9560068249702454, "xmin": 204.0, "xmax": 821.0, "ymin": 2909.0, "ymax": 2956.0, "cx": 512.5, "cy": 2932.5}, {"text": "(B)適合急性期精神病人", "conf": 0.9889760613441467, "xmin": 1226.0, "xmax": 1718.0, "ymin": 2914.0, "ymax": 2985.0, "cx": 1472.0, "cy": 2949.5}, {"text": "(C)較適合症狀穩定的病人", "conf": 0.9353708624839783, "xmin": 203.0, "xmax": 726.0, "ymin": 2985.0, "ymax": 3036.0, "cx": 464.5, "cy": 3010.5}, {"text": "(D)主要由醫事人員所主導", "conf": 0.9736810326576233, "xmin": 1223.0, "xmax": 1768.0, "ymin": 2993.0, "ymax": 3069.0, "cx": 1495.5, "cy": 3031.0}, {"text": "36", "conf": 0.999869167804718, "xmin": 68.0, "xmax": 136.0, "ymin": 3061.0, "ymax": 3115.0, "cx": 102.0, "cy": 3088.0}, {"text": "有關危機處置的技巧，下列何者正確？", "conf": 0.9931805729866028, "xmin": 200.0, "xmax": 999.0, "ymin": 3062.0, "ymax": 3115.0, "cx": 599.25, "cy": 3088.25}, {"text": "(A)危機處置必須以長期漸進的問題解決為目的", "conf": 0.9976462721824646, "xmin": 200.0, "xmax": 1155.0, "ymin": 3135.0, "ymax": 3196.0, "cx": 677.25, "cy": 3165.75}, {"text": "(C)會談中宜阻止病人哭泣，以特殊情境進入事件中", "conf": 0.993392288684845, "xmin": 195.0, "xmax": 1250.0, "ymin": 3282.0, "ymax": 3354.0, "cx": 722.25, "cy": 3317.75}, {"text": "(D)澄清是指影響病人去接受某個信念或想法", "conf": 0.9971985816955566, "xmin": 195.0, "xmax": 1106.0, "ymin": 3361.0, "ymax": 3422.0, "cx": 650.5, "cy": 3391.75}]