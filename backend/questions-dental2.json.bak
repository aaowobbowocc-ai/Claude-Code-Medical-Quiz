{
  "questions": [
    {
      "id": "110020_1",
      "roc_year": "110",
      "session": "第一次",
      "exam_code": "110020",
      "subject": "卷一",
      "subject_tag": "periodontics",
      "subject_name": "牙周病學",
      "stage_id": 2,
      "number": 1,
      "question": "陳先生是腦中風患者,在例行牙科檢查中,牙醫師發現他的左下大臼齒有嚴重齲齒,需要填補治療,但治療時 也可能會侵犯牙髓。牙醫師應進行何種處理較為妥適?",
      "options": {
        "A": "根據「代理決定」原則,開始幫患者進行牙科治療",
        "B": "根據「代理決定」原則,在家屬同意後,開始幫患者進行牙科治療",
        "C": "根據「告知」原則,向患者解釋後,開始幫患者進行牙科治療",
        "D": "根據「告知」原則,向患者解釋並尋求同意後再治療。若患者無法理解或表達,家屬同意後,可幫患者進行 牙科治療"
      },
      "answer": "D"
    },
    {
      "id": "110020_2",
      "roc_year": "110",
      "session": "第一次",
      "exam_code": "110020",
      "subject": "卷一",
      "subject_tag": "oral_surgery",
      "subject_name": "口腔顎面外科",
      "stage_id": 1,
      "number": 2,
      "question": "牙根形成階段,牙根尖閉合於何時完成(apical closure)?",
      "options": {
        "A": "於牙齒萌出時",
        "B": "大約於牙齒萌出後 1年",
        "C": "大約於牙齒萌出後 3年",
        "D": "大約於牙齒萌出後 5年"
      },
      "answer": "C"
    },
    {
      "id": "110020_3",
      "roc_year": "110",
