[{"text": "代號：5106", "conf": 0.9923057556152344, "xmin": 2037.0, "xmax": 2316.0, "ymin": 72.0, "ymax": 154.0, "cx": 2176.5, "cy": 112.75}, {"text": "頁次：8-5", "conf": 0.976309061050415, "xmin": 2040.0, "xmax": 2297.0, "ymin": 135.0, "ymax": 217.0, "cx": 2168.5, "cy": 176.25}, {"text": "37", "conf": 0.9998441934585571, "xmin": 81.0, "xmax": 151.0, "ymin": 273.0, "ymax": 328.0, "cx": 116.0, "cy": 300.5}, {"text": "有關自殺防治策略的說明，下列何者正確？", "conf": 0.995725154876709, "xmin": 201.0, "xmax": 1131.0, "ymin": 274.0, "ymax": 351.0, "cx": 666.0, "cy": 312.5}, {"text": "(A)自殺防治策略主要分為3個主要層面擬定方案，分為區域性（localization）、選擇性（selection）", "conf": 0.9521484375, "xmin": 202.0, "xmax": 2323.0, "ymin": 333.0, "ymax": 433.0, "cx": 1262.75, "cy": 382.75}, {"text": "指標性（indicator）策略", "conf": 0.9799447059631348, "xmin": 257.0, "xmax": 784.0, "ymin": 433.0, "ymax": 505.0, "cx": 520.5, "cy": 469.25}, {"text": "(B)自殺防治之推行，與心理衛生體系及社會安全體系功能之充分發揮密切相關", "conf": 0.9908164143562317, "xmin": 209.0, "xmax": 1866.0, "ymin": 501.0, "ymax": 582.0, "cx": 1037.5, "cy": 541.5}, {"text": "(C)選擇性自殺防治策略之標的為全體民眾，涵蓋導正媒體、減少致命性物品之可近性、降低自殺與", "conf": 0.991913914680481, "xmin": 211.0, "xmax": 2336.0, "ymin": 572.0, "ymax": 657.0, "cx": 1273.75, "cy": 614.25}, {"text": "精神疾病的社會污名化程度", "conf": 0.9987082481384277, "xmin": 260.0, "xmax": 852.0, "ymin": 662.0, "ymax": 725.0, "cx": 556.0, "cy": 693.5}, {"text": "(D)指標性自殺防治以高風險群為對象，包括憂鬱症共同照護體系之推行", "conf": 0.9833148717880249, "xmin": 213.0, "xmax": 1715.0, "ymin": 732.0, "ymax": 798.0, "cx": 964.0, "cy": 765.0}, {"text": "38", "conf": 0.9998329877853394, "xmin": 82.0, "xmax": 158.0, "ymin": 801.0, "ymax": 865.0, "cx": 119.75, "cy": 833.0}, {"text": "王先生因自傷傷人而由警消單位帶入強制住院，進病房後因出院需求未獲滿足立即舉起椅子砸向護", "conf": 0.9980541467666626, "xmin": 210.0, "xmax": 2331.0, "ymin": 799.0, "ymax": 871.0, "cx": 1270.5, "cy": 835.0}, {"text": "理站，有關照護措施，下列何者正確？", "conf": 0.9982222318649292, "xmin": 210.0, "xmax": 1034.0, "ymin": 881.0, "ymax": 944.0, "cx": 622.0, "cy": 912.25}, {"text": "(A)護理師可立即自行予以約束協助王先生控制情緒", "conf": 0.9921426773071289, "xmin": 215.0, "xmax": 1279.0, "ymin": 956.0, "ymax": 1013.0, "cx": 747.0, "cy": 984.5}, {"text": "(B)護理師應無論王先生的情緒狀態，先依醫囑給予王先生藥物註射，再協助控制躁動情緒", "conf": 0.9932202696800232, "xmin": 212.0, "xmax": 2117.0, "ymin": 1023.0, "ymax": 1091.0, "cx": 1164.5, "cy": 1057.0}, {"text": "(C)護理師應先評估王先生的反應，維持安全適當位置並進行自我防護準備", "conf": 0.9979166388511658, "xmin": 215.0, "xmax": 1764.0, "ymin": 1104.0, "ymax": 1161.0, "cx": 989.5, "cy": 1132.5}, {"text": "(D)護理師應立即滿足王先生的需求，以緩解情緒", "conf": 0.9935657382011414, "xmin": 216.0, "xmax": 1230.0, "ymin": 1178.0, "ymax": 1234.0, "cx": 723.0, "cy": 1206.0}, {"text": "39", "conf": 0.9808339476585388, "xmin": 86.0, "xmax": 156.0, "ymin": 1249.0, "ymax": 1305.0, "cx": 121.0, "cy": 1277.0}, {"text": "關於自閉症類群障礙症（原為自閉性疾患）的描述，下列何者正確？", "conf": 0.993796169757843, "xmin": 215.0, "xmax": 1656.0, "ymin": 1251.0, "ymax": 1308.0, "cx": 935.5, "cy": 1279.5}, {"text": "(A)喜歡玩車子的輪子之儀式化行為", "conf": 0.9960135221481323, "xmin": 217.0, "xmax": 942.0, "ymin": 1325.0, "ymax": 1383.0, "cx": 579.5, "cy": 1354.0}, {"text": "(B)喜歡主動參與「扮家家酒」的遊戲", "conf": 0.9946134090423584, "xmin": 1246.0, "xmax": 2039.0, "ymin": 1321.0, "ymax": 1385.0, "cx": 1642.25, "cy": 1353.0}, {"text": "(C)堅持每天走固定的路線回家之儀式化行為", "conf": 0.9716629981994629, "xmin": 218.0, "xmax": 1131.0, "ymin": 1400.0, "ymax": 1456.0, "cx": 674.5, "cy": 1428.0}, {"text": "(D)對感官刺激反應過強的仿說言語", "conf": 0.9955207705497742, "xmin": 1247.0, "xmax": 1986.0, "ymin": 1399.0, "ymax": 1454.0, "cx": 1616.5, "cy": 1426.5}, {"text": "40", "conf": 0.9998574256896973, "xmin": 86.0, "xmax": 155.0, "ymin": 1474.0, "ymax": 1529.0, "cx": 120.5, "cy": 1501.5}, {"text": "許小姐被家人送來急診，醫師在病歷上寫許小姐有自殺企圖（suicide attempt），下列何項屬於自殺", "conf": 0.9616531133651733, "xmin": 208.0, "xmax": 2336.0, "ymin": 1457.0, "ymax": 1542.0, "cx": 1272.0, "cy": 1499.75}, {"text": "企圖的評估？", "conf": 0.9580368995666504, "xmin": 215.0, "xmax": 501.0, "ymin": 1550.0, "ymax": 1605.0, "cx": 358.0, "cy": 1577.5}, {"text": "(A)許小姐表示有想死的念頭，但是還沒有想到要怎麼進行", "conf": 0.9959052801132202, "xmin": 217.0, "xmax": 1420.0, "ymin": 1622.0, "ymax": 1677.0, "cx": 818.5, "cy": 1649.5}, {"text": "(B)許小姐正在寫遺書", "conf": 0.9741992950439453, "xmin": 219.0, "xmax": 652.0, "ymin": 1701.0, "ymax": 1749.0, "cx": 435.5, "cy": 1725.0}, {"text": "(C)許小姐要求男朋友來急診探望，不然要自殺", "conf": 0.9954202175140381, "xmin": 217.0, "xmax": 1178.0, "ymin": 1772.0, "ymax": 1823.0, "cx": 697.5, "cy": 1797.5}, {"text": "(D)許小姐有藥物過量且手腕上有自己割傷的傷□", "conf": 0.9727872610092163, "xmin": 219.0, "xmax": 1224.0, "ymin": 1845.0, "ymax": 1896.0, "cx": 721.5, "cy": 1870.5}, {"text": "41", "conf": 0.9998605251312256, "xmin": 87.0, "xmax": 152.0, "ymin": 1912.0, "ymax": 1964.0, "cx": 119.5, "cy": 1938.0}, {"text": "在聯合國所提出的2030永續發展目標（Sustainable Development Goals，SDGs）中，社區護理人員可", "conf": 0.9735695123672485, "xmin": 214.0, "xmax": 2330.0, "ymin": 1913.0, "ymax": 1971.0, "cx": 1272.0, "cy": 1942.0}, {"text": "提供下列那一項專業貢獻？", "conf": 0.9752929210662842, "xmin": 215.0, "xmax": 788.0, "ymin": 1987.0, "ymax": 2042.0, "cx": 501.75, "cy": 2014.25}, {"text": "(A)消除極端貧窮與饑餓", "conf": 0.9947484135627747, "xmin": 216.0, "xmax": 702.0, "ymin": 2057.0, "ymax": 2114.0, "cx": 459.0, "cy": 2085.75}, {"text": "(B)促進性別平等", "conf": 0.9415839314460754, "xmin": 1248.0, "xmax": 1590.0, "ymin": 2061.0, "ymax": 2112.0, "cx": 1418.75, "cy": 2086.5}, {"text": "(C)改善弱勢易感族群健康", "conf": 0.9685525298118591, "xmin": 215.0, "xmax": 748.0, "ymin": 2127.0, "ymax": 2187.0, "cx": 481.75, "cy": 2157.0}, {"text": "(D)確保環境的永續性", "conf": 0.9616554379463196, "xmin": 1249.0, "xmax": 1685.0, "ymin": 2132.0, "ymax": 2185.0, "cx": 1467.0, "cy": 2158.5}, {"text": "42", "conf": 0.9999030232429504, "xmin": 86.0, "xmax": 158.0, "ymin": 2205.0, "ymax": 2262.0, "cx": 122.0, "cy": 2233.5}, {"text": "我國全民健康保險採全民強制納保制度，可能導致被保險者傾向過度使用醫療服務所造成的問題", "conf": 0.9961100220680237, "xmin": 212.0, "xmax": 2329.0, "ymin": 2204.0, "ymax": 2262.0, "cx": 1270.5, "cy": 2233.0}, {"text": "稱為下列何者？", "conf": 0.9420019388198853, "xmin": 213.0, "xmax": 544.0, "ymin": 2275.0, "ymax": 2333.0, "cx": 378.5, "cy": 2304.0}, {"text": "(A)逆選擇(adverse selection）", "conf": 0.918367326259613, "xmin": 216.0, "xmax": 816.0, "ymin": 2351.0, "ymax": 2405.0, "cx": 516.0, "cy": 2378.0}, {"text": "(B）道德危害（moralhazard）", "conf": 0.9398399591445923, "xmin": 1251.0, "xmax": 1824.0, "ymin": 2355.0, "ymax": 2402.0, "cx": 1537.5, "cy": 2378.5}, {"text": "(C)權益危害（righthazard）", "conf": 0.9200624227523804, "xmin": 217.0, "xmax": 765.0, "ymin": 2429.0, "ymax": 2477.0, "cx": 491.0, "cy": 2453.0}, {"text": "(D)自由選擇（free option)", "conf": 0.9054622650146484, "xmin": 1249.0, "xmax": 1784.0, "ymin": 2425.0, "ymax": 2476.0, "cx": 1516.25, "cy": 2450.5}, {"text": "43", "conf": 0.9998995661735535, "xmin": 83.0, "xmax": 152.0, "ymin": 2500.0, "ymax": 2554.0, "cx": 117.5, "cy": 2527.0}, {"text": "為服務轄區之失智長者，下列何種指標最適合作為規劃社區關懷據點數目的依據？", "conf": 0.9968182444572449, "xmin": 213.0, "xmax": 1953.0, "ymin": 2500.0, "ymax": 2554.0, "cx": 1083.0, "cy": 2527.0}, {"text": "(A)發生率", "conf": 0.9591216444969177, "xmin": 210.0, "xmax": 409.0, "ymin": 2569.0, "ymax": 2625.0, "cx": 309.5, "cy": 2597.0}, {"text": "(B)盛行率", "conf": 0.9575452208518982, "xmin": 718.0, "xmax": 919.0, "ymin": 2571.0, "ymax": 2630.0, "cx": 818.75, "cy": 2600.75}, {"text": "(C)死亡率", "conf": 0.9261505603790283, "xmin": 1245.0, "xmax": 1448.0, "ymin": 2569.0, "ymax": 2624.0, "cx": 1346.25, "cy": 2596.75}, {"text": "(D)致死率", "conf": 0.9396634697914124, "xmin": 1780.0, "xmax": 1985.0, "ymin": 2572.0, "ymax": 2627.0, "cx": 1882.75, "cy": 2599.75}, {"text": "44", "conf": 0.9997910857200623, "xmin": 80.0, "xmax": 149.0, "ymin": 2646.0, "ymax": 2700.0, "cx": 114.5, "cy": 2673.0}, {"text": "每年6~8月藉由殺蟲劑的噴灑以防止登革熱的傳染，是屬於那一種傳染病防治的策略？", "conf": 0.9786105751991272, "xmin": 205.0, "xmax": 2085.0, "ymin": 2643.0, "ymax": 2703.0, "cx": 1144.75, "cy": 2673.0}, {"text": "(A)消滅致病原", "conf": 0.9956399202346802, "xmin": 208.0, "xmax": 502.0, "ymin": 2718.0, "ymax": 2770.0, "cx": 355.0, "cy": 2744.0}, {"text": "(B)減少傳染原的傳染力", "conf": 0.9690778255462646, "xmin": 1246.0, "xmax": 1736.0, "ymin": 2719.0, "ymax": 2772.0, "cx": 1491.0, "cy": 2745.5}, {"text": "(C)傳播媒介的控制", "conf": 0.9727194905281067, "xmin": 207.0, "xmax": 599.0, "ymin": 2792.0, "ymax": 2842.0, "cx": 403.0, "cy": 2817.0}, {"text": "(D)增加宿主的免疫力", "conf": 0.9725348949432373, "xmin": 1244.0, "xmax": 1688.0, "ymin": 2793.0, "ymax": 2852.0, "cx": 1466.0, "cy": 2822.5}, {"text": "45", "conf": 0.999881386756897, "xmin": 76.0, "xmax": 144.0, "ymin": 2864.0, "ymax": 2919.0, "cx": 110.0, "cy": 2891.5}, {"text": "當 PM2.5 指數過高時，社區衛生護理人員衛教社區居民外出需戴口罩，此作法乃三段五級預防模式", "conf": 0.984688401222229, "xmin": 200.0, "xmax": 2328.0, "ymin": 2860.0, "ymax": 2931.0, "cx": 1264.0, "cy": 2895.5}, {"text": "的那一項？", "conf": 0.9419927597045898, "xmin": 196.0, "xmax": 442.0, "ymin": 2933.0, "ymax": 2994.0, "cx": 319.0, "cy": 2963.5}, {"text": "(A)健康促進", "conf": 0.959073007106781, "xmin": 197.0, "xmax": 452.0, "ymin": 3007.0, "ymax": 3067.0, "cx": 324.5, "cy": 3036.75}, {"text": "(B)特殊保護", "conf": 0.9777588844299316, "xmin": 715.0, "xmax": 960.0, "ymin": 3015.0, "ymax": 3069.0, "cx": 837.5, "cy": 3041.75}, {"text": "(C)早期治療", "conf": 0.9627655744552612, "xmin": 1240.0, "xmax": 1496.0, "ymin": 3015.0, "ymax": 3075.0, "cx": 1368.0, "cy": 3044.75}, {"text": "D)限制殘障", "conf": 0.8389697074890137, "xmin": 1780.0, "xmax": 2035.0, "ymin": 3026.0, "ymax": 3084.0, "cx": 1907.75, "cy": 3054.75}, {"text": "46", "conf": 0.9997811317443848, "xmin": 68.0, "xmax": 142.0, "ymin": 3080.0, "ymax": 3138.0, "cx": 105.0, "cy": 3109.0}, {"text": "多重抗藥性肺結核（MDR-TB）的逐漸增加，目前WHO在肺結核治療大力推動的方法為下列何者?", "conf": 0.9789895415306091, "xmin": 194.0, "xmax": 2320.0, "ymin": 3074.0, "ymax": 3166.0, "cx": 1257.0, "cy": 3120.0}, {"text": "(A) DOTS(Directly-Observed Treatment, Short-course)", "conf": 0.963054895401001, "xmin": 196.0, "xmax": 1315.0, "ymin": 3154.0, "ymax": 3216.0, "cx": 755.25, "cy": 3185.0}, {"text": "(B) IDOTS(Indirectly-Observed Treatment, Short-course)", "conf": 0.9540590643882751, "xmin": 195.0, "xmax": 1363.0, "ymin": 3227.0, "ymax": 3293.0, "cx": 779.0, "cy": 3260.0}, {"text": "(C) DOTL(Directly-Observed Treatment, Long-course)", "conf": 0.9528759717941284, "xmin": 192.0, "xmax": 1316.0, "ymin": 3297.0, "ymax": 3366.0, "cx": 753.75, "cy": 3331.25}, {"text": "(D) IDOTL(Indirectly-Observed Treatment, Long-course)", "conf": 0.9362619519233704, "xmin": 189.0, "xmax": 1365.0, "ymin": 3368.0, "ymax": 3442.0, "cx": 777.0, "cy": 3405.25}]