      "subject": "醫學(五)",
      "subject_tag": "",
      "subject_name": "",
      "stage_id": 0,
      "number": 40,
      "question": "下列何種疾病會有大於90%的比率發生JAK2 V617F 的基因突變?",
      "options": {
        "A": "polycythemia vera",
        "B": "essential thrombocythemia",
        "C": "primary myelofibrosis",
        "D": "chronic neutrophilic leukemia"
      },
